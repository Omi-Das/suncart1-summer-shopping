BETTER_AUTH_SECRET=your_strong_secret_here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Use your Atlas connection string in production
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/suncart?retryWrites=true&w=majority
MONGODB_DATABASE=suncart

# Set to 1 for local embedded MongoDB in development
MONGO_URI_EMBEDDED=0

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
